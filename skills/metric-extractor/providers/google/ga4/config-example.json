{
  "name": "ga4_users_28d",
  "description": "GA4 total users on <your-domain> over the last 28 days (property <your-ga4-property-id>)",
  "auth": {
    "type": "service_account",
    "credentials_file": "analytics/credentials/<your-gcp-project>-<service-account-name>.json",
    "scopes": ["https://www.googleapis.com/auth/analytics.readonly"],
    "quota_project": "<your-gcp-project>"
  },
  "request": {
    "url": "https://analyticsdata.googleapis.com/v1beta/properties/<your-ga4-property-id>:runReport",
    "method": "POST",
    "body": {
      "dateRanges": [{"startDate": "{{today-28d}}", "endDate": "{{today}}"}],
      "metrics": [{"name": "totalUsers"}]
    }
  },
  "extract": {
    "type": "jsonpath",
    "path": "rows.0.metricValues.0.value",
    "cast": "int",
    "default_value": 0
  },
  "validate": { "min": 0, "max": 10000000 }
}
